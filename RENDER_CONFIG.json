{
  "type": "web",
  "name": "campus-interview-tracking-system",
  "env": "node",
  "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && npm install",
  "startCommand": "cd backend && node server.js",
  "envVars": [
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "PORT",
      "value": "10000"
    },
    {
      "key": "MONGO_URI",
      "placeholder": "mongodb+srv://<username>:<password>@cluster0.mongodb.net/placement"
    },
    {
      "key": "JWT_SECRET",
      "placeholder": "generate_a_long_secure_random_string"
    }
  ]
}
